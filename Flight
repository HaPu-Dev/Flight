local function stopFly()
    flyEnabled = false
    
    if heartbeatEvent then 
        heartbeatEvent:Disconnect() 
        heartbeatEvent = nil
    end
    
    if pos then 
        pos:Destroy() 
        pos = nil 
    end
    if gyro then 
        gyro:Destroy() 
        gyro = nil 
    end
    
    local char = plr.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
        end
        
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then 
            humanoid.PlatformStand = false 
        end
        
        resetCharacterCollision(char)
    end
    
    setNoclipState(false)
    setShiftlock(false)
    
    toggleButton.Text = "GO"
    toggleButton.BackgroundColor3 = Color3.fromRGB(0,130,210)
end

local function startFly()
    if flyEnabled then return end
    
    flyEnabled = true
    toggleButton.Text = "STOP"
    toggleButton.BackgroundColor3 = Color3.fromRGB(200,60,60)

    local char = plr.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not root or not humanoid then 
        flyEnabled = false
        return 
    end

    pos = Instance.new("BodyPosition")
    gyro = Instance.new("BodyGyro")
    pos.Position = root.Position
    pos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    pos.P = 50000
    pos.D = 2000
    gyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    gyro.P = 50000
    gyro.D = 2000
    gyro.CFrame = cam.CFrame
    pos.Parent = root
    gyro.Parent = root
    
    humanoid.PlatformStand = true
    
    setNoclipState(true)
    setShiftlock(true)

    heartbeatEvent = run.Heartbeat:Connect(function()
        if not flyEnabled then return end
        
        local currentChar = plr.Character
        local currentRoot = currentChar and currentChar:FindFirstChild("HumanoidRootPart")
        local currentHumanoid = currentChar and currentChar:FindFirstChildOfClass("Humanoid")
        
        if not currentRoot or not currentHumanoid then 
            return 
        end
        
        if pos then
            pos.Position = currentRoot.Position
        end
        
        if gyro then
            gyro.CFrame = cam.CFrame
        end
        
        local moveDir = currentHumanoid.MoveDirection
        
        if moveDir.Magnitude > 0 then
            local camLook = cam.CFrame.LookVector
            
            local horizontal = moveDir
            local vertical = Vector3.new(0, 0, 0)
            
            if moveDir:Dot(cam.CFrame.LookVector) > 0 then
                vertical = Vector3.new(0, camLook.Y, 0)
            end
            
            local moveVector = (horizontal + vertical).Unit * (speed * 50)
            
            if pos then
                pos.Position = pos.Position + moveVector
            end
        end
        
        if currentChar then
            for _, o in ipairs(currentChar:GetDescendants()) do
                if o:IsA("BasePart") then
                    o.CanCollide = false
                end
            end
        end
        
        currentHumanoid.PlatformStand = true
    end)
end

speedInput.FocusLost:Connect(function()
    local num = tonumber(speedInput.Text)
    if num and num > 0 then 
        speed = num 
        speedInput.Text = tostring(speed)
    else
        speedInput.Text = tostring(speed)
    end
end)

toggleButton.MouseButton1Click:Connect(function()
    if flyEnabled then
        stopFly()
    else
        startFly()
    end
end)

toggleButton.MouseEnter:Connect(function()
    if not flyEnabled then
        toggleButton.BackgroundColor3 = Color3.fromRGB(0,150,230)
    else
        toggleButton.BackgroundColor3 = Color3.fromRGB(220,70,70)
    end
end)

toggleButton.MouseLeave:Connect(function()
    if not flyEnabled then
        toggleButton.BackgroundColor3 = Color3.fromRGB(0,130,210)
    else
        toggleButton.BackgroundColor3 = Color3.fromRGB(200,60,60)
    end
end)

plr.CharacterRemoving:Connect(function() 
    if flyEnabled then stopFly() end
end)
