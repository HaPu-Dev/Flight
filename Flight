inputCorner.Parent = speedInput

local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0, 45, 0, 22)
toggleButton.Text = "GO"
toggleButton.TextSize = 10
toggleButton.Font = Enum.Font.GothamBold
toggleButton.TextColor3 = Color3.new(1,1,1)
toggleButton.BackgroundColor3 = Color3.fromRGB(0,130,210)
toggleButton.BorderSizePixel = 0
toggleButton.Parent = mainFrame

local buttonCorner = Instance.new("UICorner")
buttonCorner.CornerRadius = UDim.new(0, 12)
buttonCorner.Parent = toggleButton

speedInput.FocusLost:Connect(function()
local val = tonumber(speedInput.Text)
if val then
flightSpeed = math.clamp(val, MIN_SPEED, MAX_SPEED)
speedInput.Text = tostring(flightSpeed)
else
speedInput.Text = tostring(flightSpeed)
end
end)

local function toggleFlight()
flightActive = not flightActive

if flightActive then      
    toggleButton.Text = "✈"      
    toggleButton.BackgroundColor3 = Color3.fromRGB(200,60,60)      
  
    enableNoclip()      
    playFlightAnimation()      
    startContinuousTrails()      
    startFlight()      
else      
    toggleButton.Text = "GO"      
    toggleButton.BackgroundColor3 = Color3.fromRGB(0,130,210)      
  
    stopFlight()      
    stopContinuousTrails()      
    stopFlightAnimation()      
    disableNoclip()      
end

end

toggleButton.MouseButton1Click:Connect(toggleFlight)

player.CharacterAdded:Connect(function(char)
character = char
humanoid = char:WaitForChild("Humanoid")
rootPart = char:WaitForChild("HumanoidRootPart")

flightActive = false      
stopFlightAnimation()      
uncarpet()      
disableNoclip()      
stopContinuousTrails()

end)

print("Flight script with compact pill GUI and infinite speed loaded!")
