local plr = game:GetService("Players").LocalPlayer
local run = game:GetService("RunService")
local cam = workspace.CurrentCamera
local playerGui = plr:WaitForChild("PlayerGui")
local userInputService = game:GetService("UserInputService")

local flyEnabled = false
local speed = 2
local pos, gyro, heartbeatEvent

local function setShiftlock(state)
    pcall(function()
        game:GetService("StarterGui"):SetCore("ShiftLock", state)
        if state then
            userInputService:SetMouseBehavior(Enum.MouseBehavior.LockCurrentPosition)
        else
            userInputService:SetMouseBehavior(Enum.MouseBehavior.Default)
        end
    end)
end

local function resetCharacterCollision(char)
    if not char then return end
    for _, o in ipairs(char:GetDescendants()) do
        if o:IsA("BasePart") then
            local name = o.Name:lower()
            if name:find("torso") or name:find("root") or name:find("head") then
                o.CanCollide = true
            else
                o.CanCollide = false
            end
        end
    end
end

local function setNoclipState(state)
    local char = plr.Character
    if state and char then
        for _, o in ipairs(char:GetDescendants()) do
            if o:IsA("BasePart") then
                o.CanCollide = false
            end
        end
    elseif not state and char then
        resetCharacterCollision(char)
    end
end

