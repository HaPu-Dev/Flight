local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")
local camera = workspace.CurrentCamera

local MIN_SPEED = 0
local MAX_SPEED = math.huge
local DEFAULT_SPEED = 150

local flightSpeed = DEFAULT_SPEED
local flightActive = false
local originalProperties = {}
local flightConnection = nil
local noclipConnection = nil
local animationTrack = nil
local trailConnection = nil

local function uncarpet()
local char = player.Character or player.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")
for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
if track.Animation and track.Animation.AnimationId == "rbxassetid://282574440" then
track:Stop()
end
end
end

local function playFlightAnimation()
uncarpet()
local anim = Instance.new("Animation")
anim.AnimationId = "rbxassetid://282574440"
animationTrack = humanoid:LoadAnimation(anim)
animationTrack.Looped = true
animationTrack:Play()
end

local function stopFlightAnimation()
uncarpet()
end

local TRAIL_CONFIG = {
enabled = true,
color = Color3.fromRGB(255,255,255),
width = 0.15,
maxSegmentLength = 2,
fadeTime = 0.5,
}

local trailParts = {}
local lastLeftPos, lastRightPos = nil, nil

local function createContinuousTrail(startPos, endPos)
local distance = (endPos - startPos).Magnitude
local midpoint = startPos + (endPos - startPos)/2

local part = Instance.new("Part")      
part.Size = Vector3.new(TRAIL_CONFIG.width, distance, TRAIL_CONFIG.width)      
part.CFrame = CFrame.new(midpoint, endPos) * CFrame.Angles(math.rad(90),0,0)      
part.Anchored = true      
part.CanCollide = false      
part.Material = Enum.Material.Neon      
part.Color = TRAIL_CONFIG.color      
part.Parent = workspace      
  
table.insert(trailParts, part)      
TweenService:Create(part, TweenInfo.new(TRAIL_CONFIG.fadeTime), {Transparency = 1}):Play()      
game:GetService("Debris"):AddItem(part, TRAIL_CONFIG.fadeTime)

end

local function startContinuousTrails()
if trailConnection then trailConnection:Disconnect() end
lastLeftPos, lastRightPos = nil, nil
trailParts = {}

trailConnection = RunService.Heartbeat:Connect(function()      
    if not flightActive or not character then return end      
  
    local leftArm = character:FindFirstChild("Left Arm") or character:FindFirstChild("LeftLowerArm")      
    local rightArm = character:FindFirstChild("Right Arm") or character:FindFirstChild("RightLowerArm")      
  
    if leftArm then      
        if lastLeftPos then      
            if (leftArm.Position - lastLeftPos).Magnitude >= TRAIL_CONFIG.maxSegmentLength then      
                createContinuousTrail(lastLeftPos, leftArm.Position)      
                lastLeftPos = leftArm.Position      
            end      
        else      
            lastLeftPos = leftArm.Position      
        end      
    end      
  
    if rightArm then      
        if lastRightPos then      
            if (rightArm.Position - lastRightPos).Magnitude >= TRAIL_CONFIG.maxSegmentLength then      
                createContinuousTrail(lastRightPos, rightArm.Position)      
                lastRightPos = rightArm.Position      
            end      
        else      
            lastRightPos = rightArm.Position      
        end      
    end      
end)

end

local function stopContinuousTrails()
if trailConnection then
trailConnection:Disconnect()
trailConnection = nil
end
for _, part in ipairs(trailParts) do
if part and part.Parent then
part:Destroy()
end
end
trailParts = {}
lastLeftPos, lastRightPos = nil, nil
end

local function enableNoclip()
for _, part in pairs(character:GetDescendants()) do
if part:IsA("BasePart") then
originalProperties[part] = part.CanCollide
part.CanCollide = false
end
end

if noclipConnection then noclipConnection:Disconnect() end      
noclipConnection = RunService.Heartbeat:Connect(function()      
    if not flightActive or not character then return end      
    for _, part in pairs(character:GetDescendants()) do      
        if part:IsA("BasePart") then      
            part.CanCollide = false      
        end      
    end      
end)

end

local function disableNoclip()
if noclipConnection then
noclipConnection:Disconnect()
noclipConnection = nil
end
for part, state in pairs(originalProperties) do
if part and part.Parent then
part.CanCollide = state
end
end
originalProperties = {}
end

local function startFlight()
if flightConnection then flightConnection:Disconnect() end

flightConnection = RunService.RenderStepped:Connect(function()      
    if not flightActive then return end      
  
    local dir = camera.CFrame.LookVector.Unit      
    rootPart.AssemblyLinearVelocity = dir * flightSpeed      
    rootPart.AssemblyAngularVelocity = Vector3.zero      
    rootPart.CFrame = CFrame.new(rootPart.Position, rootPart.Position + dir)      
end)

end

local function stopFlight()
if flightConnection then
flightConnection:Disconnect()
flightConnection = nil
end
rootPart.AssemblyLinearVelocity = Vector3.zero
rootPart.AssemblyAngularVelocity = Vector3.zero
end

